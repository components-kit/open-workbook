{
  "name": "@components-kit/open-workbook-excel-addin",
  "version": "0.1.12",
  "description": "Office.js Excel add-in runtime for Open Workbook local automation.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/open-workbook.git",
    "directory": "apps/excel-addin"
  },
  "bugs": {
    "url": "https://github.com/components-kit/open-workbook/issues"
  },
  "keywords": [
    "excel",
    "office-js",
    "addin",
    "mcp"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build",
    "build:client": "vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "npm-run-all --parallel dev:ts dev:client dev:server",
    "dev:client": "vite build --watch",
    "dev:ts": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:server": "node scripts/dev-server.mjs",
    "serve": "node scripts/dev-server.mjs"
  },
  "dependencies": {
    "@components-kit/open-workbook-excel-core": "workspace:*",
    "@components-kit/open-workbook-protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.492",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "npm-run-all": "^4.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
