{
  "name": "@component-kit/open-workbook-excel-core",
  "version": "0.1.0",
  "description": "Core planning, backup, snapshot, template, permission, and range utilities for Open Workbook.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/open-workbook/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-workbook/open-workbook.git",
    "directory": "packages/excel-core"
  },
  "bugs": {
    "url": "https://github.com/open-workbook/open-workbook/issues"
  },
  "keywords": [
    "excel",
    "spreadsheet",
    "planning",
    "backup",
    "template"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@component-kit/open-workbook-protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
