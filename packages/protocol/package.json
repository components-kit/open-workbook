{
  "name": "@components-kit/open-workbook-protocol",
  "version": "0.1.3",
  "description": "Shared Open Workbook protocol types, tool catalog, resources, prompts, and JSON-RPC contracts.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/open-workbook.git",
    "directory": "packages/protocol"
  },
  "bugs": {
    "url": "https://github.com/components-kit/open-workbook/issues"
  },
  "keywords": [
    "mcp",
    "excel",
    "protocol",
    "json-rpc",
    "spreadsheet"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
