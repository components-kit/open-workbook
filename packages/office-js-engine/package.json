{
  "name": "@components-kit/open-workbook-office-js-engine",
  "version": "0.1.5",
  "description": "Office.js engine interfaces and defaults for Open Workbook Excel execution.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
