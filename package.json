{
  "name": "open-workbook",
  "version": "0.1.25",
  "private": true,
  "description": "Local-first MCP runtime for fast, reversible, template-aware Excel automation.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/open-workbook.git"
  },
  "bugs": {
    "url": "https://github.com/components-kit/open-workbook/issues"
  },
  "keywords": [
    "excel",
    "office-js",
    "mcp",
    "openrouter",
    "spreadsheet",
    "automation"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "node scripts/build/clean-dist.mjs && tsc -b --pretty false && corepack pnpm --filter @components-kit/open-workbook-excel-addin build:client && corepack pnpm --filter @components-kit/open-workbook package:assets && node scripts/build/chmod-bins.mjs",
    "check": "tsc -b --pretty false",
    "test": "corepack pnpm -r test",
    "catalog:check": "node scripts/validate/mcp-surface.mjs",
    "capabilities:report": "node scripts/reports/capability-coverage.mjs",
    "operations:manifest": "node scripts/reports/operation-manifest.mjs",
    "operations:check": "node scripts/reports/operation-manifest.mjs --check",
    "diagnose:session": "node scripts/diagnostics/session-diagnostics.mjs",
    "llms:generate": "node scripts/docs/generate-llms-full.mjs",
    "skills:check": "node scripts/validate/skills.mjs",
    "docs:check": "node scripts/validate/docs-surface.mjs",
    "package:check": "node scripts/validate/package-metadata.mjs",
    "smoke:cli": "node tests/smoke/cli.mjs",
    "test:regression:opencode": "pnpm --filter @components-kit/open-workbook-backend exec vitest run src/agent-orchestrator.preview-apply.test.ts -t \"OpenCode production regressions\"",
    "test:e2e": "node tests/e2e/mcp-contract.mjs && node tests/e2e/workbook-fixture.mjs && node tests/e2e/scenario-fixture-contract.mjs && node tests/e2e/agent-surface.mjs && node tests/e2e/agent-workflow.mjs && node tests/e2e/office-agent-behavior.mjs --strict --scenarios status-active-workbook,sales-header-format-preview,sales-update-status-preview && node tests/e2e/office-agent-behavior.mjs --strict --scenario-file tests/e2e/fixtures/office-agent-regression-scenarios.json && node tests/e2e/office-agent-behavior.mjs --strict --scenario-file tests/e2e/fixtures/office-agent-department-scenarios.json",
    "test:e2e:mcp-contract": "node tests/e2e/mcp-contract.mjs",
    "test:e2e:workbook": "node tests/e2e/workbook-fixture.mjs",
    "test:e2e:scenario-contract": "node tests/e2e/scenario-fixture-contract.mjs",
    "test:e2e:scenarios": "node tests/e2e/office-agent-behavior.mjs --strict --scenarios status-active-workbook,sales-header-format-preview,sales-update-status-preview",
    "test:e2e:scenarios:category": "node tests/e2e/office-agent-behavior.mjs --strict --category formatting",
    "test:e2e:scenarios:full": "node tests/e2e/office-agent-behavior.mjs --strict --scenarios all",
    "test:e2e:scenarios:regression": "node tests/e2e/office-agent-behavior.mjs --strict --scenario-file tests/e2e/fixtures/office-agent-regression-scenarios.json",
    "test:e2e:scenarios:departments": "node tests/e2e/office-agent-behavior.mjs --strict --scenario-file tests/e2e/fixtures/office-agent-department-scenarios.json",
    "test:e2e:agent-surface": "node tests/e2e/agent-surface.mjs",
    "test:e2e:agent-workflow": "node tests/e2e/agent-workflow.mjs",
    "test:e2e:office-agent:behavior": "node tests/e2e/office-agent-behavior.mjs",
    "test:e2e:agent": "node tests/e2e/codex-agent.mjs --scenarios core",
    "test:e2e:agent:core": "node tests/e2e/codex-agent.mjs --scenarios core",
    "test:e2e:agent:quality": "node tests/e2e/codex-agent.mjs --scenarios quality --report-only",
    "test:e2e:agent:quality:cheap": "node tests/e2e/codex-agent.mjs --scenarios quality --report-only --model gpt-5.4-mini",
    "test:e2e:agent:quality:frontier": "node tests/e2e/agent-model-matrix.mjs --profiles frontier --scenarios quality",
    "test:e2e:agent:quality:compare": "node tests/e2e/agent-model-matrix.mjs --profiles cheap,frontier --scenarios quality",
    "test:e2e:agent:quality:gate": "node tests/e2e/agent-model-matrix.mjs --profiles cheap,frontier --scenarios quality --strict",
    "test:e2e:agent:quality:cheap:strict": "node tests/e2e/codex-agent.mjs --scenarios quality --model gpt-5.4-mini",
    "test:e2e:agent:full": "node tests/e2e/codex-agent.mjs --scenarios all --report-only",
    "test:e2e:agent:codex": "node tests/e2e/codex-agent.mjs --scenarios core",
    "test:e2e:live:mac": "node tests/e2e/live-smoke.mjs --platform mac",
    "test:e2e:live:windows": "node tests/e2e/live-smoke.mjs --platform windows",
    "test:e2e:live:mac:regression": "node tests/e2e/live-smoke.mjs --platform mac --scenario-group scratch-core,regression-pack,template-formula-repair,pivot-chart-core,pivot-template-repair,chart-template-copy",
    "test:e2e:live:windows:regression": "node tests/e2e/live-smoke.mjs --platform windows --scenario-group scratch-core,regression-pack,template-formula-repair,pivot-chart-core,pivot-template-repair,chart-template-copy",
    "test:e2e:release": "pnpm build && pnpm test:e2e",
    "verify:release": "pnpm verify && pnpm test:e2e",
    "benchmark:synthetic": "corepack pnpm build && node tests/benchmarks/synthetic.mjs",
    "pack:dry-run": "node scripts/release/package-dry-run.mjs",
    "publish:npm": "node scripts/release/publish-npm.mjs",
    "verify": "pnpm build && pnpm catalog:check && pnpm operations:check && pnpm llms:generate && pnpm skills:check && pnpm docs:check && pnpm package:check && pnpm smoke:cli && pnpm test && node tests/benchmarks/synthetic.mjs",
    "dev:backend": "pnpm --filter @components-kit/open-workbook-backend dev",
    "dev:mcp": "pnpm --filter @components-kit/open-workbook-mcp-server dev",
    "dev:addin": "pnpm --filter @components-kit/open-workbook-excel-addin dev",
    "dev:local": "zsh scripts/dev/local.sh",
    "dev:local:sideload": "zsh scripts/dev/local.sh --sideload-mac",
    "sideload:mac": "node packages/cli/dist/index.js sideload mac --development",
    "sideload:windows": "node packages/cli/dist/index.js sideload windows --development --out open-workbook-local.xml"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
