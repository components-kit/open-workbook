{
  "name": "open-workbook",
  "version": "0.1.4",
  "private": true,
  "description": "Local-first MCP runtime for fast, reversible, template-aware Excel automation.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/open-workbook.git"
  },
  "bugs": {
    "url": "https://github.com/components-kit/open-workbook/issues"
  },
  "keywords": [
    "excel",
    "office-js",
    "mcp",
    "openrouter",
    "spreadsheet",
    "automation"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -b --pretty false && corepack pnpm --filter @components-kit/open-workbook-excel-addin build:client && node scripts/package-cli-assets.mjs && node scripts/chmod-bins.mjs",
    "check": "tsc -b --pretty false",
    "test": "corepack pnpm -r test",
    "catalog:check": "node scripts/validate-mcp-catalog.mjs",
    "llms:generate": "node scripts/generate-llms-full.mjs",
    "skills:check": "node scripts/validate-skills.mjs",
    "docs:check": "node scripts/validate-docs-surface.mjs",
    "package:check": "node scripts/validate-package-metadata.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "benchmark:synthetic": "corepack pnpm build && node scripts/benchmark-synthetic.mjs",
    "pack:dry-run": "node scripts/package-dry-run.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "verify": "corepack pnpm build && corepack pnpm catalog:check && corepack pnpm llms:generate && corepack pnpm skills:check && corepack pnpm docs:check && corepack pnpm package:check && corepack pnpm smoke:cli && corepack pnpm test && node scripts/benchmark-synthetic.mjs",
    "dev:backend": "corepack pnpm --filter @components-kit/open-workbook-backend dev",
    "dev:mcp": "corepack pnpm --filter @components-kit/open-workbook-mcp-server dev",
    "dev:addin": "corepack pnpm --filter @components-kit/open-workbook-excel-addin dev",
    "dev:local": "zsh scripts/dev-local.sh",
    "dev:local:sideload": "zsh scripts/dev-local.sh --sideload-mac",
    "sideload:mac": "node scripts/sideload-mac.mjs",
    "sideload:windows": "node scripts/sideload-windows.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
