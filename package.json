{
  "name": "open-workbook",
  "version": "0.1.14",
  "private": true,
  "description": "Local-first MCP runtime for fast, reversible, template-aware Excel automation.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/components-kit/open-workbook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/components-kit/open-workbook.git"
  },
  "bugs": {
    "url": "https://github.com/components-kit/open-workbook/issues"
  },
  "keywords": [
    "excel",
    "office-js",
    "mcp",
    "openrouter",
    "spreadsheet",
    "automation"
  ],
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -b --pretty false && corepack pnpm --filter @components-kit/open-workbook-excel-addin build:client && node scripts/package-cli-assets.mjs && node scripts/chmod-bins.mjs",
    "check": "tsc -b --pretty false",
    "test": "corepack pnpm -r test",
    "catalog:check": "node scripts/validate-mcp-catalog.mjs && node scripts/validate-optimized-surface.mjs && node scripts/validate-agent-surface.mjs",
    "llms:generate": "node scripts/generate-llms-full.mjs",
    "skills:check": "node scripts/validate-skills.mjs",
    "docs:check": "node scripts/validate-docs-surface.mjs",
    "package:check": "node scripts/validate-package-metadata.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "test:e2e": "corepack pnpm test:e2e:report && corepack pnpm test:e2e:agent-surface && corepack pnpm test:e2e:agent-workflow && corepack pnpm test:e2e:fast && corepack pnpm test:e2e:agent:core",
    "test:e2e:report": "node scripts/e2e-report.mjs",
    "test:e2e:agent-surface": "node scripts/e2e-agent-surface.mjs",
    "test:e2e:agent-workflow": "node scripts/e2e-agent-workflow.mjs",
    "test:e2e:office-agent:behavior": "node scripts/e2e-office-agent-behavior.mjs",
    "test:e2e:fast": "node scripts/e2e-fast.mjs",
    "test:e2e:agent": "corepack pnpm test:e2e:agent:core",
    "test:e2e:agent:core": "node scripts/e2e-codex-agent.mjs --scenarios core",
    "test:e2e:agent:quality": "node scripts/e2e-codex-agent.mjs --scenarios quality --report-only",
    "test:e2e:agent:quality:cheap": "node scripts/e2e-codex-agent.mjs --scenarios quality --report-only --model gpt-5.4-mini",
    "test:e2e:agent:quality:frontier": "node scripts/e2e-agent-model-matrix.mjs --profiles frontier --scenarios quality",
    "test:e2e:agent:quality:compare": "node scripts/e2e-agent-model-matrix.mjs --profiles cheap,frontier --scenarios quality",
    "test:e2e:agent:quality:gate": "node scripts/e2e-agent-model-matrix.mjs --profiles cheap,frontier --scenarios quality --strict",
    "test:e2e:agent:quality:cheap:strict": "node scripts/e2e-codex-agent.mjs --scenarios quality --model gpt-5.4-mini",
    "test:e2e:agent:full": "node scripts/e2e-codex-agent.mjs --scenarios all --report-only",
    "test:e2e:agent:codex": "corepack pnpm test:e2e:agent",
    "test:e2e:agent:codex:with-report": "corepack pnpm test:e2e:report && corepack pnpm test:e2e:agent",
    "test:e2e:live:mac": "node scripts/e2e-live-smoke.mjs --platform mac",
    "test:e2e:live:windows": "node scripts/e2e-live-smoke.mjs --platform windows",
    "test:e2e:release": "corepack pnpm build && corepack pnpm test:e2e:report && corepack pnpm test:e2e:fast && corepack pnpm test:e2e:agent:core",
    "verify:release": "corepack pnpm verify && corepack pnpm test:e2e:report && corepack pnpm test:e2e:fast && corepack pnpm test:e2e:agent:core",
    "benchmark:synthetic": "corepack pnpm build && node scripts/benchmark-synthetic.mjs",
    "pack:dry-run": "node scripts/package-dry-run.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "verify": "corepack pnpm build && corepack pnpm catalog:check && corepack pnpm llms:generate && corepack pnpm skills:check && corepack pnpm docs:check && corepack pnpm package:check && corepack pnpm smoke:cli && corepack pnpm test && node scripts/benchmark-synthetic.mjs",
    "dev:backend": "corepack pnpm --filter @components-kit/open-workbook-backend dev",
    "dev:mcp": "corepack pnpm --filter @components-kit/open-workbook-mcp-server dev",
    "dev:addin": "corepack pnpm --filter @components-kit/open-workbook-excel-addin dev",
    "dev:local": "zsh scripts/dev-local.sh",
    "dev:local:sideload": "zsh scripts/dev-local.sh --sideload-mac",
    "sideload:mac": "node scripts/sideload-mac.mjs",
    "sideload:windows": "node scripts/sideload-windows.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
